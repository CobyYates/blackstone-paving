# ------------------------------------------------------------------------------
# Blackstone Paving - environment variables
# Copy this file to `.env` and fill in real values. On Cloudflare Pages, set
# the same keys under Settings → Environment variables (Production + Preview).
# Nuxt automatically maps NUXT_* / NUXT_PUBLIC_* vars onto runtimeConfig.
# ------------------------------------------------------------------------------

# --- Storyblok (headless CMS) -------------------------------------------------
# Preview token = live draft content for the Visual Editor & local dev.
# Use the PUBLIC token for production builds if you only want published content.
NUXT_STORYBLOK_ACCESS_TOKEN=

# Management API - ONLY used by `npm run sb:sync` to push block schemas to
# Storyblok. Not used at runtime; leave blank on Cloudflare Pages.
# Token: Personal Access Token, or Space → Settings → Access tokens (Management).
STORYBLOK_MANAGEMENT_TOKEN=
STORYBLOK_SPACE_ID=

# --- Site (SEO: canonical URLs, sitemap, robots, schema.org) ------------------
# No trailing slash. Use the real production domain.
NUXT_PUBLIC_SITE_URL=https://blackstone-paving.com

# --- EmailJS (contact / quote forms - client-side submission) -----------------
# These are public by design (safe to expose in the browser).
NUXT_PUBLIC_EMAILJS_SERVICE_ID=
NUXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NUXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# --- Analytics (public IDs - safe to expose) ----------------------------------
# Optional overrides. Sensible defaults for this site are baked into
# nuxt.config.ts, so leave blank unless deploying to a different property.
# Analytics load in PRODUCTION builds only (not `npm run dev`).
NUXT_PUBLIC_GTM_ID=GTM-NLKDP32D
NUXT_PUBLIC_GTAG_ID=G-VELHLHQMLT
